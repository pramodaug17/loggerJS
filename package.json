{
  "name": "liteloggerjs",
  "version": "1.0.0",
  "description": "This is logger for browser with window in page",
  "license": "MIT",
  "author": "Pramod Jain",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pramodaug17/loggerJS.git"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/@types/index.d.ts",
  "unpkg": "dist/litelogger.js",
  "exports": {
    ".": {
      "types": "./dist/@types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/@types/browser.d.ts",
      "import": "./dist/browser.js",
      "require": "./dist/browser.cjs"
    },
    "./node": {
      "types": "./dist/@types/node.d.ts",
      "import": "./dist/node.js",
      "require": "./dist/node.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build:tsup": "tsup && shx mv dist/browser.global.js dist/litelogger.js",
    "build:types": "tsc -p ./tsconfig.types.json",
    "build": "pnpm run build:tsup && pnpm run build:types",
    "test": "echo \"Error: no test specified\" && exit 0"
  },
  "keywords": [
    "logger",
    "logger js",
    "browser logger",
    "lite logger",
    "liteloggerjs"
  ],
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "esbuild": "^0.28.0",
    "shx": "^0.4.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}